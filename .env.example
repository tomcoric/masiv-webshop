# ── Masiva webshop — primjer environment varijabli ──
# Kopiraj ovu datoteku u `.env` i popuni stvarnim vrijednostima.
# NIKADA ne commitati pravi `.env` u git.

# Osnovno
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Masiva"

# ── Baza podataka (dodaje se u fazi backenda) ──
# DATABASE_URL="postgresql://korisnik:lozinka@localhost:5432/masiva"

# ── Autentifikacija admina (dodaje se kasnije) ──
# AUTH_SECRET=""

# ── Email (potvrde narudžbi, dodaje se kasnije) ──
# EMAIL_FROM="info@masiva.hr"
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""

# ── S3 storage za slike proizvoda (dodaje se kasnije) ──
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""

# ── Payment provider (kartice — modularni adapter, dodaje se kasnije) ──
# PAYMENT_PROVIDER="bank_transfer"
